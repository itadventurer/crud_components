<% fieldset = params[:view] == 'catalog' ? :catalog : :index %>
<% layout = params[:layout] == 'cards' ? :cards : :table %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @publisher ? "Books by #{@publisher.name}" : @author ? "Books by #{@author.name}" : 'Books' %></h1>
  <div class="d-flex gap-2">
    <div class="btn-group">
      <%= link_to 'Curated', url_for(view: nil),
                  class: "btn btn-sm #{fieldset == :index ? 'btn-secondary' : 'btn-outline-secondary'}" %>
      <%= link_to 'Catalog', url_for(view: 'catalog'),
                  class: "btn btn-sm #{fieldset == :catalog ? 'btn-secondary' : 'btn-outline-secondary'}" %>
    </div>
    <div class="btn-group">
      <%= link_to 'Table', url_for(layout: nil),
                  class: "btn btn-sm #{layout == :table ? 'btn-dark' : 'btn-outline-dark'}" %>
      <%= link_to 'Cards', url_for(layout: 'cards'),
                  class: "btn btn-sm #{layout == :cards ? 'btn-dark' : 'btn-outline-dark'}" %>
    </div>
  </div>
</div>

<% if layout == :cards %>
<%= docs_panel(
      intro: "&ldquo;Cards&rdquo; is a <strong>custom layout you add</strong> &mdash; the gem ships only the built-in <code>:table</code>. Drop one partial that receives the same <code>collection</code> presenter (still driven by the <code>:#{fieldset}</code> fieldset) and arrange the markup however you like; the gem still derives the fields, cells, filtering, sorting and actions for you. A card grid has <strong>no column headers</strong>, so <code>crud_filter</code> takes <code>sort: true</code> to carry the sort picker.",
      docs: { 'Add a layout' => 'docs/extending.md#add-a-layout', 'Views' => 'docs/views.md' }) do %>
<%= code_file('app/views/crud_components/layouts/_cards.html.erb', :erb) do %>
&lt;% collection.records.each do |record| %&gt;
  &lt;div class="card card-body"&gt;
    &lt;% collection.fields.each do |f| %&gt;&lt;%= collection.cell(f, record) %&gt;&lt;% end %&gt;
  &lt;/div&gt;
&lt;% end %&gt;
<% end %>
<%= code_file('app/views/books/index.html.erb', :erb) do %>
&lt;%= crud_collection @books, fieldset: :<%= fieldset %>, layout: :cards %&gt;
&lt;%= crud_filter   Book, fieldset: :<%= fieldset %>, sort: true %&gt;   &lt;%# headerless → carry the sort picker %&gt;
<% end %>
<% end %>
<% else %>
<%= docs_panel(
      intro: "A full table &mdash; search, an inline filter row, sortable columns and row actions &mdash; all derived from the model. This page toggles between the curated <code>:index</code> and the fuller <code>:catalog</code> fieldset (currently <code>:#{fieldset}</code>). Your controller assigns <code>@books</code> &mdash; scope it for authorization (e.g. <code>Book.accessible_by(current_ability)</code>) and the gem renders that scope.",
      docs: { 'Fields & cells' => 'docs/fields.md', 'Views & fieldsets' => 'docs/views.md' }) do %>
<%= code_file('app/models/book.rb') do %>
crud_structure do
  attribute :price, as: :number, unit: '€', digits: 2
  fieldset :index,   %i[cover title author_names genre price publisher active]
  fieldset :catalog, %i[cover title subtitle author_names genre price purchase_price
                        shop_margin pages published_on publisher reviews active manual created_at]
end
<% end %>
<%= code_file('app/views/books/index.html.erb', :erb) do %>
&lt;%= crud_collection @books, fieldset: :<%= fieldset %> %&gt;   &lt;%# search, filters, sort, actions %&gt;
&lt;%= crud_filter   Book, fieldset: :<%= fieldset %> %&gt;     &lt;%# filter sidebar (takes the model, not a scope) %&gt;
<% end %>
<% end %>
<% end %>

<div class="row">
  <div class="col-xl-9">
    <div class="card"><div class="card-body">
      <%= crud_collection @books, fieldset: fieldset, layout: layout %>
    </div></div>
  </div>
  <div class="col-xl-3">
    <div class="card"><div class="card-body">
      <h5 class="card-title">Filter</h5>
      <%# Cards have no column headers, so let the filter form carry the sort picker. %>
      <%= crud_filter Book, fieldset: fieldset, sort: layout == :cards %>
    </div></div>
  </div>
</div>
