<h1>Export</h1>
<%= docs_panel(
      intro: "A <strong>selection action</strong> (<code>action :export_selected, on: :selection</code>). The table's checkboxes submit <code>selected[]=&lt;slug&gt;</code>; <code>CrudComponents.selected(Book, params)</code> turns that back into a scope. This page just lists them &mdash; a real app would stream a CSV.",
      docs: { 'Selection actions' => 'docs/views.md#selection-bulk-actions' }) do %>
<%= code_file('app/controllers/books_controller.rb') do %>
def export_selected
  @books = CrudComponents.selected(Book, params)   # selected[]=slug,… → relation
end
<% end %>
<% end %>

<p class="text-muted">These items would be exported:</p>
<ul class="list-group mb-3">
  <% @books.each do |book| %>
    <li class="list-group-item"><%= book.title %></li>
  <% end %>
  <% if @books.empty? %>
    <li class="list-group-item text-muted">Nothing selected.</li>
  <% end %>
</ul>
<%= link_to '← Back to books', books_path, class: 'btn btn-outline-secondary' %>
