<%# Locals: path (filename), lang (highlight.js language), code (html_safe). %>
<div class="bg-body-secondary border rounded-top px-3 py-1 small text-muted d-flex align-items-center gap-2">
  <i class="bi bi-file-earmark-code"></i><%= path %>
</div>
<pre class="border border-top-0 rounded-bottom mb-3 p-3"><code class="language-<%= lang %>"><%= code %></code></pre>
