<!DOCTYPE html>
<html>
<head>
  <title>CrudComponents Playground</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <script type="module">
    import * as Turbo from "https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.12/+esm"
    import { Application, Controller } from "https://cdn.jsdelivr.net/npm/@hotwired/stimulus@3.2.2/+esm"

    // The gem's one optional Stimulus controller (normally copied in via
    // `rails g crud_components:install`) — inlined here since the dummy app
    // has no build step.
    class CrudFilterController extends Controller {
      static targets = ["form"]
      clean() {
        this.cleaned = []
        for (const element of this.form.elements) {
          if (element.name && element.value === "" && !element.disabled) {
            element.disabled = true
            this.cleaned.push(element)
          }
        }
        setTimeout(() => {
          this.cleaned.forEach((element) => (element.disabled = false))
          this.cleaned = []
        }, 500)
      }
      submit() { this.form.requestSubmit() }
      get form() { return this.hasFormTarget ? this.formTarget : this.element }
    }

    // Optional progressive enhancement (NOT part of the gem): turn the habtm
    // checkbox baseline into a token/chip widget — chips with × to remove, a
    // dropdown to add. The checkboxes remain the source of truth (hidden), so
    // the form submits identically with or without this controller.
    class CrudTokensController extends Controller {
      connect() {
        this.boxes = Array.from(this.element.querySelectorAll('input[type=checkbox]'))
        if (!this.boxes.length) return
        this.element.querySelectorAll('.form-check').forEach((el) => (el.style.display = 'none'))
        this.element.style.maxHeight = 'none'

        this.chips = document.createElement('div')
        this.chips.className = 'd-flex flex-wrap gap-1 mb-2'
        this.adder = document.createElement('select')
        this.adder.className = 'form-select form-select-sm'
        this.element.prepend(this.adder)
        this.element.prepend(this.chips)
        this.adder.addEventListener('change', () => this.add())
        this.render()
      }
      label(box) { return this.element.querySelector(`label[for="${box.id}"]`).textContent.trim() }
      render() {
        this.chips.innerHTML = ''
        this.boxes.filter((b) => b.checked).forEach((box) => {
          const chip = document.createElement('span')
          chip.className = 'badge text-bg-primary d-inline-flex align-items-center gap-1'
          chip.textContent = this.label(box)
          const x = document.createElement('button')
          x.type = 'button'; x.className = 'btn-close btn-close-white'; x.style.fontSize = '.6rem'
          x.addEventListener('click', () => { box.checked = false; this.render() })
          chip.append(x); this.chips.append(chip)
        })
        this.adder.innerHTML = '<option value="">+ add…</option>'
        this.boxes.filter((b) => !b.checked).forEach((box) => {
          const opt = document.createElement('option'); opt.value = box.id; opt.textContent = this.label(box)
          this.adder.append(opt)
        })
      }
      add() {
        const box = this.boxes.find((b) => b.id === this.adder.value)
        if (box) { box.checked = true; this.render() }
      }
    }

    const application = Application.start()
    application.register("crud-filter", CrudFilterController)
    application.register("crud-tokens", CrudTokensController)
  </script>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand bg-dark navbar-dark mb-4">
    <div class="container-fluid">
      <span class="navbar-brand">CrudComponents</span>
      <div class="navbar-nav me-auto">
        <%= link_to 'Books', books_path, class: 'nav-link' %>
        <%= link_to 'Publishers', publishers_path, class: 'nav-link' %>
        <%= link_to 'Authors (zero config)', authors_path, class: 'nav-link' %>
        <%= link_to 'Reviews', reviews_path, class: 'nav-link' %>
        <%= link_to 'Dashboard (two collections)', dashboard_path, class: 'nav-link' %>
      </div>
      <%= button_to admin? ? 'Admin ✓ (click to drop)' : 'Become admin', toggle_admin_path,
                    class: "btn btn-sm #{admin? ? 'btn-warning' : 'btn-outline-light'}" %>
    </div>
  </nav>
  <main class="container-fluid px-4">
    <% if notice %><div class="alert alert-success"><%= notice %></div><% end %>
    <%= yield %>
  </main>
</body>
</html>
