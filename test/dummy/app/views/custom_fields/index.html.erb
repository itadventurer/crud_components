<h1 class="mb-3">Custom fields</h1>

<%= docs_panel(
      intro: "User-defined properties that live <em>outside</em> the Book table " \
             "(here in a #{link_to 'property_values', 'https://github.com/itadventurer/crud_components/blob/main/test/dummy/app/models/property_definition.rb', class: 'link-secondary'} store) " \
             "shown as extra columns. The model is untouched — the controller loads each " \
             "<code>PropertyDefinition</code> and turns it into a <code>CrudComponents::DynamicColumn</code>, then " \
             "passes the set as <code>extra_columns:</code>. Each column carries a <code>preload:</code> (one query " \
             "per page, no N+1) and <code>filter:</code>/<code>sort:</code> facets, so <strong>Shelf</strong> (string), " \
             "<strong>Weight</strong> (number, in g), <strong>Signed</strong> (boolean) and <strong>Acquired</strong> " \
             "(date) sort and filter like real columns. Try the filter row and the sort headers.".html_safe,
      docs: { 'Dynamic columns' => 'docs/fields.md#dynamic-columns', 'Views' => 'docs/views.md' }) do %>
<%= code_file('app/controllers/custom_fields_controller.rb') do %>
@books   = Book.all
@columns = PropertyDefinition.order(:id).map { |defn| defn.to_crud_column(Book) }
<% end %>
<%= code_file('app/models/property_definition.rb') do %>
def to_crud_column(subject_model)
  definition = self
  CrudComponents::DynamicColumn.new(
    key.to_sym, label: label, as: renderer, unit: unit.presence,
    preload: -&gt;(records) { definition.values_by_subject(subject_model, records) },  # one query/page
    filter:  -&gt;(scope, value) { definition.filter_scope(scope, subject_model, value) },
    sort:    -&gt;(scope, dir)   { definition.sort_scope(scope, subject_model, dir) }
  ) { |record, loaded| definition.cast(loaded[record.id]&amp;.value) }                   # the value resolver
end
<% end %>
<%= code_file('app/views/custom_fields/index.html.erb', :erb) do %>
&lt;%= crud_collection @books, fieldset: :compact, extra_columns: @columns %&gt;
<% end %>
<% end %>

<div class="card"><div class="card-body">
  <%= crud_collection @books, fieldset: :compact, extra_columns: @columns %>
</div></div>
