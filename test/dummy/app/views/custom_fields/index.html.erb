<h1 class="mb-3">Custom fields</h1>

<%= docs_panel(
      intro: "User-defined properties that live <em>outside</em> the Book table " \
             "(here in a #{link_to 'property_values', 'https://github.com/itadventurer/crud_components/blob/main/test/dummy/app/models/property_definition.rb', class: 'link-secondary'} store) " \
             "shown as extra columns. The model is untouched — the controller loads each " \
             "<code>PropertyDefinition</code> and turns it into a <code>CrudComponents::DynamicColumn</code>, then " \
             "passes the set as <code>extra_columns:</code> — to both <code>crud_collection</code> and the standalone " \
             "<code>crud_filter</code> form. Each column carries a <code>preload:</code> (one query per page, no N+1), a " \
             "<strong>typed</strong> <code>filter:</code> and a <code>sort:</code> — so <strong>Shelf</strong> (text), " \
             "<strong>Weight</strong> (number range, in g), <strong>Signed</strong> (yes/no select) and " \
             "<strong>Acquired</strong> (date range) filter with the control their type wants, not a plain text box. " \
             "Try the inline filter row, the sort headers, and the sidebar form.".html_safe,
      docs: { 'Dynamic columns' => 'docs/fields.md#dynamic-columns', 'Views' => 'docs/views.md' }) do %>
<%= code_file('app/controllers/custom_fields_controller.rb') do %>
@books   = Book.all
@columns = []
@columns << CrudComponents::DynamicColumn.new(
  :price_usd,
  label: 'Price (USD)',
  as: :number,
  unit: '$',
  filter: ->(scope, geq:, leq:) { scope.where('price*1.1 >= ?', geq).where('price*1.1 <= ?', leq) },
  sort: ->(scope, dir) { scope.order(Arel.sql("(price*1.1) #{dir}")) }
) { |record| record.price * 1.1 }

@columns += PropertyDefinition.order(:id).map { |defn| defn.to_crud_column(Book) }

<% end %>
<%= code_file('app/models/property_definition.rb') do %>
def to_crud_column(subject_model)
  definition = self
  CrudComponents::DynamicColumn.new(
    key.to_sym, label: label, as: renderer, unit: unit.presence,
    preload: -&gt;(records) { definition.values_by_subject(subject_model, records) },  # one query/page
    filter:  definition.filter_for(subject_model),   # filters as the as: type (see below)
    sort:    -&gt;(scope, dir) { definition.sort_scope(scope, subject_model, dir) }
  ) { |record, loaded| definition.cast(loaded[record.id]&amp;.value) }                   # the value resolver
end

# Just a block — its control follows the column's as: flavor (number → range,
# date → range, boolean → yes/no, string → text):
def filter_for(subject_model)
  case flavor
  when 'number'  then -&gt;(s, geq:, leq:) { ... }
  when 'boolean' then -&gt;(s, eq:) { ... }
  when 'date'    then -&gt;(s, geq:, leq:) { ... }
  else                -&gt;(s, contains:) { ... }
  end
end
<% end %>
<%= code_file('app/views/custom_fields/index.html.erb', :erb) do %>
&lt;%= crud_collection @books, fieldset: :compact, extra_columns: @columns %&gt;
&lt;%= crud_filter   Book, fieldset: :compact, extra_columns: @columns %&gt;   &lt;%# same dynamic columns in a standalone form %&gt;
<% end %>
<% end %>

<div class="row">
  <div class="col-xl-9">
    <div class="card"><div class="card-body">
      <%= crud_collection @books, fieldset: :compact, extra_columns: @columns %>
    </div></div>
  </div>
  <div class="col-xl-3">
    <div class="card"><div class="card-body">
      <h5 class="card-title">Filter</h5>
      <%# crud_filter takes the same extra_columns: as crud_collection (issue #22),
          so the user-defined-property filters appear without hand-building a Query. %>
      <%= crud_filter Book, fieldset: :compact, extra_columns: @columns %>
    </div></div>
  </div>
</div>
