<%# Locals: value (Active Storage attachment), record, field, surface %>
<%- if value.respond_to?(:attached?) && value.attached? -%>
  <%= image_tag value, class: 'rounded crud-image',
                style: surface == :collection ? 'max-height: 2.5rem' : 'max-height: 16rem' %>
<%- else -%>
  <span class="<%= CrudComponents.config.css.muted %>">—</span>
<%- end -%>
