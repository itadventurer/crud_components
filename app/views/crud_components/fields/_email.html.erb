<%# Renders an email value as a mailto: link. Locals: value, record, field,
    surface, cell_context. Used automatically for columns named email / *_email. %>
<%- if value.nil? || value == '' -%>
  <span class="<%= CrudComponents.config.css.muted %>">—</span>
<%- else -%>
  <%= mail_to value.to_s %>
<%- end -%>
