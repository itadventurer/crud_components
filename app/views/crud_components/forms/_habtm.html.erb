<%# Locals: f, field, form — submitted as the *_ids array.
    Baseline (no JS): a checkbox list (good UX, accessible) for manageable
    sets, a multiselect above config.select_limit. The `data-controller`
    hook is an optional progressive enhancement (e.g. a token/chip widget):
    the checkboxes stay the source of truth, so the form submits identically
    with or without JS. %>
<% selected = Array(form.record.public_send(field.ids_method)).map(&:to_s) %>
<% choices = field.form_choices %>
<%- if choices.size <= CrudComponents.config.select_limit -%>
  <div class="crud-checks border rounded p-2" style="max-height: 12rem; overflow-y: auto"
       data-controller="crud-tokens">
    <%# ensures an empty array submits (deselect-all) even without JS %>
    <%= hidden_field_tag "#{f.object_name}[#{field.ids_method}][]", '', id: nil %>
    <%- choices.each do |label, id| -%>
      <% dom = "#{f.object_name}_#{field.ids_method}_#{id}" %>
      <div class="form-check">
        <input type="checkbox" class="form-check-input" id="<%= dom %>"
               name="<%= "#{f.object_name}[#{field.ids_method}][]" %>" value="<%= id %>"
               <%= 'checked' if selected.include?(id.to_s) %>>
        <label class="form-check-label" for="<%= dom %>"><%= label %></label>
      </div>
    <%- end -%>
  </div>
<%- else -%>
  <%= f.select field.ids_method, options_for_select(choices, selected),
               {}, multiple: true, size: 8, class: form.css.select_input %>
<%- end -%>
