<%# Derived create/edit form. Local: `form` (Presenters::Form).
    Saving is the host controller's job — see crud_attribute_names. %>
<%= form_with(model: form.record, **form.form_options) do |f| %>
  <% if form.any_errors? %>
    <div class="alert alert-danger">
      <%= t('crud_components.form.errors',
            count: form.record.errors.count,
            default: 'Please fix %{count} error(s) below.') %>
      <% if form.summary_errors.any? %>
        <ul class="mb-0 mt-1">
          <% form.summary_errors.each do |message| %><li><%= message %></li><% end %>
        </ul>
      <% end %>
    </div>
  <% end %>

  <% form.fields.each do |field| %>
    <% if form.control(field) == :readonly %>
      <%# Read-only fields are reference, not input — keep them compact. %>
      <div class="mb-2 small d-flex gap-2 crud-form-readonly">
        <span class="<%= form.css.muted %>"><%= field.human_name %>:</span>
        <span><%= form.display(field) %></span>
      </div>
    <% else %>
      <div class="mb-3 crud-form-field">
        <%= f.label field.name, field.human_name, class: form.css.form_label %>
        <%= render "crud_components/forms/#{form.control(field)}", f: f, field: field, form: form %>
        <% form.errors_for(field).each do |message| %>
          <div class="text-danger small"><%= message %></div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <div class="d-flex gap-2">
    <%= f.submit class: form.css.button_primary %>
  </div>
<% end %>
