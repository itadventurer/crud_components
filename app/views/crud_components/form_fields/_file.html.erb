<%# Form input for an Active Storage attachment. Locals: f, field, form.
    Uses Active Storage signed_ids so keep / add / remove all flow through the
    standard permit list (`:cover` / `{ images: [] }`) with no controller code:
      - each existing attachment carries a "keep" checkbox holding its signed_id
        (checked = keep; uncheck = remove on save);
      - the file input adds (has_many) or replaces (has_one) on upload.
    For has_one the keep checkbox is rendered AFTER the file input, so leaving
    the file empty keeps the current attachment (the kept signed_id wins over the
    empty upload); uncheck it to remove, or uncheck + choose a file to replace. %>
<% name = field.name %>
<% many = field.respond_to?(:many?) && field.many? %>
<% value = field.value(form.record) %>
<% attachments = value.respond_to?(:attached?) && value.attached? ? Array(many ? value.to_a : value) : [] %>
<div class="mb-3 crud-attachment-field">
  <%= f.label name, class: form.css.form_label %>

  <% if many %>
    <% if attachments.any? %>
      <div class="d-flex flex-wrap gap-2 mb-2">
        <% attachments.each do |attachment| %>
          <label class="d-flex flex-column align-items-center gap-1 border rounded p-1 crud-attachment-keep">
            <%= render 'crud_components/fields/attachment_thumb', attachment: attachment, surface: :collection %>
            <span class="form-check small mb-0">
              <%= check_box_tag "#{f.object_name}[#{name}][]", attachment.signed_id, true, id: nil, class: 'form-check-input' %>
              <%= t('crud_components.attachment.keep', default: 'Keep') %>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>
    <%= file_field_tag "#{f.object_name}[#{name}][]", multiple: true, class: form.css.input %>
  <% else %>
    <% attachment = attachments.first %>
    <% if attachment %>
      <div class="mb-2"><%= render 'crud_components/fields/attachment_thumb', attachment: attachment, surface: :record %></div>
    <% end %>
    <%= file_field_tag "#{f.object_name}[#{name}]", class: form.css.input %>
    <% if attachment %>
      <span class="form-check small mt-1">
        <%= check_box_tag "#{f.object_name}[#{name}]", attachment.signed_id, true, id: nil, class: 'form-check-input' %>
        <%= t('crud_components.attachment.keep_one', default: 'Keep current (uncheck to remove; uncheck + choose a file to replace)') %>
      </span>
    <% end %>
  <% end %>
</div>
